{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "zk-guard",
          "version": "{VERSION}",
          "informationUri": "https://github.com/ThirdChildren/ZK_Guard",
          "rules": [
            {
              "id": "NOIR-PUBLIC-001",
              "name": "Public input declared but unused in a constraint-relevant expression",
              "shortDescription": {
                "text": "Public input declared but unused in a constraint-relevant expression"
              },
              "fullDescription": {
                "text": "Detects `pub` parameters of `fn main` that never reach a constraint."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "security-severity": "8.0",
                "confidence": "medium",
                "tags": [
                  "security"
                ]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "NOIR-PUBLIC-001",
          "ruleIndex": 0,
          "level": "error",
          "message": {
            "text": "A public input that never reaches an assert is not bound.\n\nEvidence: pub claimed_total: Field\n\nRemediation: Bind every public input to at least one constraint."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/main.nr"
                },
                "region": {
                  "startLine": 10
                }
              }
            }
          ]
        }
      ]
    }
  ]
}